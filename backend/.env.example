# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connections
MONGODB_URI=
MONGODB_URI_FALLBACK=

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173



# Google OAuth
GOOGLE_CLIENT_ID=

# Email Configuration (Brevo/SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Borzo Delivery (Logistics)
BORZO_API_TOKEN=
BORZO_CALLBACK_TOKEN=
BORZO_BASE_URL=https://robotapitest-in.borzodelivery.com/api/business/1.6

# Shadowfax Delivery (Logistics)
SHADOWFAX_API_KEY=
SHADOWFAX_BASE_URL=https://dale.staging.shadowfax.in/api

# Delivery Mode Switch ('borzo' or 'shadowfax')
DELIVERY_PROVIDER=borzo
